# Copia este archivo a .env y rellena los valores reales.
# .env está en .gitignore — NUNCA lo subas al repo.

# === Monday.com API ===
# Obtén tu token en: avatar → Developers → My Access Tokens
MONDAY_API_TOKEN=

# ID del board "Enterprise 2026". Lo ves en la URL del board.
MONDAY_BOARD_ID=18395174855

# Columna de estado QA. Por defecto "status"; confirma con la API si tu board usa otro id.
MONDAY_STATUS_COLUMN_ID=status

# Labels exactos del status QA del board (deben coincidir letra por letra).
# Confirmados desde el dropdown del board OS Enterprise Sprints 2026.
MONDAY_QA_PASSED_LABEL=QA Passed
MONDAY_QA_FAILED_LABEL=QA Failed

# Posteo automático: 0 = solo genera reporte local; 1 = además postea en Monday.
MONDAY_POST_ENABLED=0

# === Webhook trigger (Fase 5) ===
# Columna "people" donde el QA Manager te asigna como QA owner.
# (Confirmada en el board OS Enterprise Sprints 2026.)
MONDAY_QA_REL_COLUMN_ID=multiple_person_mkxkt529

# Tu user ID en Monday — el script auto-detecta este valor con `me { id }`
# si lo dejás vacío. Lo guardás aquí para evitar una llamada extra al runner.
MONDAY_MY_USER_ID=

# Label del status que dispara la ejecución e2e. El gate manual sigue siendo
# tuyo: tú mueves de "QA Ready" → "QA In Progress" cuando tomás el ticket.
MONDAY_QA_TRIGGER_LABEL=QA In Progress

# Puerto local donde corre el servidor de webhooks.
QA_RUNNER_PORT=8765

# Secret compartido con Monday: si lo seteás, el servidor verifica que el
# webhook venga firmado con esta clave (recomendado en producción).
MONDAY_WEBHOOK_SECRET=

# === Aplicación bajo prueba ===
BASE_URL=https://queencity.com

# === Credenciales de prueba ===
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# === Configuración de ejecución ===
# headless | headed
PLAYWRIGHT_MODE=headed

# chromium | firefox | webkit
BROWSER=chromium
